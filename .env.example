# Saniflow Configuration
# All variables are prefixed with SANIFLOW_

# Maximum upload file size in bytes (default: 20 MB)
# SANIFLOW_MAX_FILE_SIZE=20971520

# Supported MIME types (JSON array)
# SANIFLOW_SUPPORTED_FORMATS=["application/pdf","image/jpeg","image/png"]

# Default sanitization level: standard | strict
# SANIFLOW_DEFAULT_LEVEL=standard

# Confidence thresholds (0.0 - 1.0)
# SANIFLOW_CONFIDENCE_THRESHOLD_REGEX=0.7
# SANIFLOW_CONFIDENCE_THRESHOLD_NER=0.5

# Tesseract OCR language
# SANIFLOW_TESSERACT_LANG=spa

# spaCy model for NER
# SANIFLOW_SPACY_MODEL=es_core_news_md

# Path to YuNet ONNX model for face detection
# SANIFLOW_YUNET_MODEL_PATH=/app/models/face_detection_yunet_2023mar.onnx

# Temporary file directory
# SANIFLOW_TEMP_DIR=/tmp/saniflow
